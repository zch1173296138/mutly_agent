# ── PostgreSQL 数据库 ─────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/deep_researcher

# ── 使用限制设置（留空则不校验，设置后前端必须在设置中填写才可使用）─────────────
ACCESS_CODE=
# ── 建表开关─────────────────
DB_AUTO_CREATE_TABLES=1

# ── LLM 服务 ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.5-plus-2026-02-15

# ── LangSmith 可观测性（可选，建议开启）───────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=deepresearch
LANGCHAIN_TRACING_V2=true

# ── 邮件发送（可选，发送报告功能） ──────────────────────────────────────────────
SENDER_EMAIL=your_email@163.com
SENDER_PASSWORD=your_smtp_password

# ── MCP 服务器密钥 ─────────────────────────────────────────────────────────────
AMAP_MAPS_API_KEY=your_amap_api_key_here

# ── MCP 服务器本机路径（跨机器时修改此处，留空则自动从 PATH 寻找）─────────────────
# UV_BIN=/home/user/.local/bin/uv
# NPX_BIN=/usr/local/bin/npx

TUSHARE_TOKEN=your_tushare_token_here
TAVILY_API_KEY=your_tavily_api_key_here
