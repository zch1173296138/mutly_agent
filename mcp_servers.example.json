{
  "mcpServers": {
    "finance-mcp": {
      "type": "python",
      "script_or_package": "app/infrastructure/local_server.py"
    },
    "amap-maps": {
      "type": "node",
      "package": "@amap/amap-maps-mcp-server",
      "env": {
        "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
      }
    },
    "tavily-search": {
      "type": "python",
      "script_or_package": "app/infrastructure/tavily_server.py",
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  }
}
